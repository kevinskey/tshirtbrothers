{
  "name": "@tshirtbrothers/design-studio",
  "version": "0.1.0",
  "description": "Fabric.js v6 design studio — canvas engine, serializer, and themeable React components. Shared by the TSB storefront and any consumer (e.g. GleeWorld) that needs a white-label design authoring experience.",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./bridge": {
      "types": "./src/components/design-studio/FabricRendererBridge.tsx",
      "import": "./src/components/design-studio/FabricRendererBridge.tsx",
      "default": "./src/components/design-studio/FabricRendererBridge.tsx"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "fabric": "^6.9.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "dependencies": {
    "opentype.js": "^1.3.5",
    "wawoff2": "^2.0.1"
  },
  "devDependencies": {
    "@types/opentype.js": "^1.3.9",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.7.2"
  }
}
