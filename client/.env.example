# Client-side build env vars (Vite). Copy to .env (not .env.local) for the
# production build on the droplet. Any var prefixed with VITE_ is exposed
# to the browser bundle — DO NOT put secrets here.

# Google Maps / Places API key. Used for address autocomplete on the
# admin Customer form. The key should be:
#   - Scoped to "Maps JavaScript API" + "Places API"
#   - HTTP-referrer restricted to tshirtbrothers.com / localhost
# If unset, the address input works as a plain text field (no autocomplete).
VITE_GOOGLE_MAPS_KEY=
