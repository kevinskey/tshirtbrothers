# ──────────────────────────────────────────────────────────────
# SERVER — copy to server/.env and fill in
# ──────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# Postgres
DATABASE_URL=postgres://songwriter:password@localhost:5432/songwriter

# Session / JWT
SESSION_SECRET=change-me-to-a-long-random-string
JWT_SECRET=change-me-too-and-make-it-different

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI in dev: http://localhost:4000/api/auth/google/callback
# Authorized redirect URI in prod: https://songwriter.yourdomain.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Where to send the user after successful login
CLIENT_URL=http://localhost:5173

# DeepSeek (reuse your existing key)
DEEPSEEK_API_KEY=

# ──────────────────────────────────────────────────────────────
# CLIENT — copy to client/.env and fill in
# ──────────────────────────────────────────────────────────────
# VITE_API_URL=http://localhost:4000
